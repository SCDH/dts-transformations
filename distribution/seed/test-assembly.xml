<?xml version="1.0" encoding="utf-8"?>
<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
   <id>seed-tests</id>
   <includeBaseDirectory>true</includeBaseDirectory>
   <baseDirectory/>

   <formats>
      <format>tar.gz</format>
   </formats>

   <fileSets>
      <fileSet>
         <directory>${project.basedir}/test</directory>
         <outputDirectory>/${project.artifactId}-test</outputDirectory>
         <includes>
            <include>**/tei2txt.xsl</include>
         </includes>
         <excludes>
            <exclude>post-proc-*</exclude>
            <exclude>specs/**</exclude>
            <exclude>**/xspec/**.xsl</exclude>
            <exclude>distribution/**</exclude>
            <exclude>scripts/**</exclude>
            <exclude>doc/**</exclude>
            <exclude>test/**</exclude>
            <exclude>utils/**</exclude>
            <exclude>target/**</exclude>
            <exclude>frameworks/**</exclude>
            <exclude>cases/**</exclude>
            <exclude>dist/**</exclude>
            <exclude>wiki/**</exclude>
         </excludes>
      </fileSet>
      <fileSet>
         <directory>${project.build.directory}/generated-resources/xml/xslt/test</directory>
         <outputDirectory>/${project.artifactId}-test</outputDirectory>
         <includes>
            <include>**/*.seed.json</include>
         </includes>
      </fileSet>
      <fileSet>
         <directory>${project.basedir}/test</directory>
         <outputDirectory>/${project.artifactId}-test</outputDirectory>
         <includes>
            <include>saxon.xml</include>
            <include>saxon-no-local.xml</include>
         </includes>
      </fileSet>
   </fileSets>

   <files>
      <file>
         <!-- TODO: make source be the chained config -->
         <source>${project.build.directory}/generated-resources/xml/xslt/pom.json</source>
         <destName>${project.artifactId}-test.json</destName>
      </file>
   </files>

</assembly>
